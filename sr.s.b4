#include <iostream>
using namespace std;

int main() {
    int array[10];

    cout << "Enter 10 numbers :" << endl;

    for (int i = 0; i < 10; i++) 
    {
        cin >> array[i];
    }

    for (int i = 0; i < 5; i++) 
    {
        int temp = array[i];
        array[i] = array[9 - i];
        array[9 - i] = temp;
    }

    cout << "Reversed array:" << endl;

    for (int i = 0; i < 10; i++) 
    {
        cout << array[i] << " ";
    }

    return 0;
}
