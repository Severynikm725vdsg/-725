#include <iostream>
using namespace std;

int main() {
    int array[20];
    int even = 0;
    int odd = 0;

    cout << "Enter 20 numbers:" << endl;

    for (int i = 0; i < 20; i++) 
    {
        cin >> array[i];

        if (array[i] % 2 == 0)
            even++;
        else
            odd++;
    }

    cout << "Even: " << even << endl;
    cout << "Odd: " << odd << endl;

    return 0;
}
