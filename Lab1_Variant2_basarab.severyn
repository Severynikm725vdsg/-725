#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Enter number: ";
    cin >> n;

    if (n >= 10 && n <= 99 && n % 2 == 0) 
    {
        cout << "The number is an even two-digit number." << endl;
    }
    else 
    {
        cout << "The number isn't an even two-digit number." << endl;
    }

    return 0;
}
